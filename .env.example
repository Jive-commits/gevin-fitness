# --- FORGE environment ---

# Postgres connection string.
# On Railway this is injected automatically by the Postgres plugin — DO NOT set it manually there.
# Locally (via docker compose) use:
DATABASE_URL="postgresql://forge:forge@localhost:5432/forge"

# Passcode that gates the whole app (single-user). Set this in Railway.
APP_PASSCODE="changeme"

# Node environment
NODE_ENV="development"

# Optional: default units shown for a fresh database. "kg" (default) or "lb".
DEFAULT_UNITS="kg"
