// FORGE — precision strength-training tracker
// Single-user now; userId-ready for a clean multi-user migration later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- LIBRARY ----------
model Exercise {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  primaryMuscle    Muscle
  secondaryMuscles Muscle[]
  movementPattern  MovementPattern
  category         Category // COMPOUND | ISOLATION
  equipment        Equipment[] // every implement it can be done with
  unilateral       Boolean         @default(false)
  spinalLoad       SpinalLoad // NONE | LOW | MODERATE | HIGH
  isBackSafe       Boolean // derived convenience flag
  defaultRepRange  String? // "8-10"
  cues             String? // short coaching cues
  tempoNote        String?
  videoUrl         String?
  isCustom         Boolean         @default(false) // user-created; never touched by seed
  slotExercises    SlotExercise[]
  setLogs          SetLog[]
  swappedInto      SlotExercise[]  @relation("DefaultExercise")
}

// ---------- PROGRAM TEMPLATE ----------
model Program {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  author      String?
  description String?
  blocks      Block[]
}

model Block {
  id        String  @id @default(cuid())
  slug      String  @unique
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String // "Block 1 — Technique & Volume"
  order     Int
  weeks     Int // 8
  phase     String // "TECHNIQUE_VOLUME" | "PEAKING_INTENSITY"
  notes     String?
  days      Day[]
}

model Day {
  id         String           @id @default(cuid())
  slug       String           @unique
  blockId    String
  block      Block            @relation(fields: [blockId], references: [id], onDelete: Cascade)
  name       String // "Legs #1"
  order      Int // 1..6
  splitType  SplitType // LEGS | PUSH | PULL
  muscleTags Muscle[]
  slots      SlotExercise[]
  sessions   WorkoutSession[]
}

model SlotExercise {
  id                String   @id @default(cuid())
  slug              String   @unique
  dayId             String
  day               Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  order             Int
  exerciseId        String // CURRENT (user-swappable)
  exercise          Exercise @relation(fields: [exerciseId], references: [id])
  defaultExerciseId String // canonical, for "reset to default"
  defaultExercise   Exercise @relation("DefaultExercise", fields: [defaultExerciseId], references: [id])
  sets              Int
  repScheme         String // "8-10", "5", "20/leg", "30s"
  targetRpe         String? // "7", "7-8"
  restSeconds       Int
  supersetGroup     String? // "A"
  supersetOrder     Int? // 1,2,3 -> A1/A2/A3
  notes             String?
  replacesNote      String?
}

// ---------- LOGGING ----------
model WorkoutSession {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  dayId       String? // null = freestyle / off-program custom workout
  day         Day?     @relation(fields: [dayId], references: [id], onDelete: Cascade)
  name        String? // optional label for custom workouts
  date        DateTime @default(now())
  notes       String?
  completed   Boolean  @default(false)
  durationSec Int?
  sets        SetLog[]

  @@index([dayId])
  @@index([date])
  @@index([userId])
}

model SetLog {
  id        String         @id @default(cuid())
  sessionId String
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise  Exercise       @relation(fields: [exerciseId], references: [id])
  slotId    String? // which prescribed slot it came from
  setNumber Int
  weightKg  Float?
  reps      Int?
  rpe       Float?
  isWarmup  Boolean        @default(false)
  completed Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@unique([sessionId, slotId, setNumber])
  @@index([exerciseId])
  @@index([sessionId])
}

model BodyMetric {
  id       String   @id @default(cuid())
  userId   String?
  user     User?    @relation(fields: [userId], references: [id])
  date     DateTime @default(now())
  weightKg Float

  @@index([date])
  @@index([userId])
}

// ---------- TENANCY ----------
// Multi-tenant foundation. Today the app runs single-tenant behind one passcode,
// so there is exactly one User ("usr_default"); getCurrentUserId() resolves to it.
// Real auth (phone OTP) plugs into that seam without further schema changes.
model User {
  id        String           @id @default(cuid())
  phone     String?          @unique
  email     String?          @unique
  name      String?
  createdAt DateTime         @default(now())
  settings  UserSettings?
  coach     CoachProfile?
  sessions  WorkoutSession[]
  metrics   BodyMetric[]
}

// ---------- SETTINGS (single-row app config) ----------
model UserSettings {
  id              String      @id @default("default")
  userId          String?     @unique
  user            User?       @relation(fields: [userId], references: [id])
  units           String      @default("lb") // "kg" | "lb"
  backSafeOnly    Boolean     @default(true)
  myEquipmentOnly Boolean     @default(true)
  availableEquipment Equipment[]
  defaultRestSec  Int         @default(120)
  incrementUpperKg Float      @default(2.5)
  incrementLowerKg Float      @default(5)
  activeProgramSlug String?
  currentDayOrder Int         @default(1) // schedule cursor 1..6
  activeBlockSlug String?
  bodyweightKg    Float?
  updatedAt       DateTime    @updatedAt
}

// ---------- AI ACCOUNTABILITY COACH ----------
// Single-row profile (id = "default"), mirroring UserSettings. Holds the lifter's
// goals + WHY (fuel for the personas) and the coach's delivery config.
model CoachProfile {
  id     String  @id @default("default")
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Onboarding — the motivation engine the personas draw from
  primaryGoal         String? // lose_fat | build_muscle | get_stronger | stay_consistent | athletic | health
  goalDetail          String? // free text, e.g. "lose 20 lb before the wedding"
  why                 String? // the deep motivation — weaponized (kindly or savagely) by the coach
  whyDeeper           String? // optional "and why does that matter to you"
  identity            String? // "the person I want to become"
  obstacles           String? // what's derailed past attempts
  trainingDaysPerWeek Int       @default(4)
  targetDate          DateTime?

  // Coach configuration
  enabled   Boolean @default(false)
  persona   String  @default("mentor") // savage | hype | mentor | zen | analyst
  intensity Int     @default(2) // 1..3 — softens or sharpens the chosen persona
  channel   String  @default("in_app") // in_app | sms | both

  // SMS delivery + TCPA compliance
  phoneNumber    String?
  smsConsent     Boolean   @default(false)
  smsConsentAt   DateTime?
  smsStopped     Boolean   @default(false) // honored an inbound STOP
  timezone       String    @default("America/New_York")
  quietStartHour Int       @default(21) // local hour, inclusive — no texts at/after
  quietEndHour   Int       @default(8) // local hour, exclusive — no texts before

  lastNudgeAt DateTime?
  onboardedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  nudges NudgeLog[]
}

model NudgeLog {
  id        String       @id @default(cuid())
  profileId String
  profile   CoachProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  direction String // outbound | inbound
  channel   String // sms | in_app
  trigger   String // missed_day | streak_risk | comeback | milestone | manual_test | reply | checkin
  persona   String? // persona snapshot at send time
  body      String
  meta      Json? // streak count, days missed, etc.
  twilioSid String?
  status    String       @default("created") // created | sent | delivered | failed | received | read
  readAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([profileId])
  @@index([createdAt])
}

enum Muscle {
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  CHEST
  LATS
  UPPER_BACK
  TRAPS
  FRONT_DELTS
  SIDE_DELTS
  REAR_DELTS
  BICEPS
  TRICEPS
  FOREARMS
  ABS
  OBLIQUES
}

enum MovementPattern {
  SQUAT
  HINGE
  LUNGE
  HORIZONTAL_PUSH
  VERTICAL_PUSH
  HORIZONTAL_PULL
  VERTICAL_PULL
  ISOLATION
  CARRY
  CORE
  CALF_RAISE
}

enum Category {
  COMPOUND
  ISOLATION
}

enum Equipment {
  BARBELL
  DUMBBELL
  SMITH_MACHINE
  CABLE
  MACHINE
  BODYWEIGHT
  BAND
  KETTLEBELL
  EZ_BAR
  PULL_UP_BAR
  BENCH
  SWISS_BALL
  SLIDER
}

enum SpinalLoad {
  NONE
  LOW
  MODERATE
  HIGH
}

enum SplitType {
  LEGS
  PUSH
  PULL
}
